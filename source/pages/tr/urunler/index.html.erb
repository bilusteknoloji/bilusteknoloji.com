---
title: Ürünler
description: Bilus Teknoloji'nin geliştirdiği ürünler. Yapay zeka, geliştirici araçları ve kurumsal çözümler.
---
<% I18n.locale = :tr %>

<section class="2xl:py-24">
    <div class="container mx-auto">
        <nav class="mx-auto mb-12 flex flex-wrap gap-4 justify-center p-5 lg:max-w-3xl lg:px-0 lg:pt-12 lg:max-w-4xl 2xl:pt-0">
            <% data.products.products[lang].sort_by{ |p| p.display_order }.each do |product| %>
            <a href="#<%= product.slug %>" class="border border-gray-200 bg-gray-50 text-gray-600 rounded-full px-5 py-2 text-sm font-medium hover:bg-bilus-500 hover:text-white hover:border-bilus-500 transition duration-200 drop-shadow-lg"><%= product.name %></a>
            <% end %>
        </nav>

        <div class="mx-auto px-5 2xl:px-0 space-y-12">
            <% data.products.products[lang].sort_by{ |p| p.display_order }.each_with_index do |product, idx| %>
            <div id="<%= product.slug %>" class="bg-white border border-bilus-100 rounded-2xl overflow-hidden shadow-sm lg:flex <%= idx.even? ? '' : 'lg:flex-row-reverse' %> scroll-mt-32">

                <div class="lg:w-1/2 overflow-hidden bg-bilus-50 flex items-center justify-center p-4 lg:p-0">
                    <%
                    img_1x = product.screenshot
                    img_2x = product.screenshot.sub('.png', '@2x.png')
                    %>
                    <img src="<%= image_path(img_1x) %>"
                         srcset="<%= image_path(img_1x) %> 1x, <%= image_path(img_2x) %> 2x"
                         alt="<%= product.name %>"
                         class="w-full h-auto m-12 border border-bilus-200 drop-shadow-2xl" />
                </div>

                <div class="p-6 lg:w-1/2 lg:p-10 flex flex-col justify-center overflow-hidden">
                    <div class="mb-3 flex flex-wrap gap-2">
                        <span class="text-xs text-bilus-400 bg-bilus-100/30 border rounded-full px-3 py-0.5 font-medium"><%= product.category %></span>
                        <% if product.respond_to?(:model) && product.model.present? %>
                        <span class="text-xs text-white bg-bilus-500 rounded-full px-3 py-0.5 font-medium"><%= product.model %></span>
                        <% end %>
                    </div>

                    <h2 class="text-2xl font-bold text-bilus-600 mb-2 lg:text-3xl"><%= product.name %></h2>
                    <p class="text-bilus-500 font-semibold mb-4 lg:text-lg"><%= product.tagline %></p>
                    <div class="text-bilus-600 leading-relaxed mb-6">
                        <%= markdownify_text_only(product.summary) %>
                    </div>

                    <ul class="space-y-2 mb-6">
                        <% product.features.each do |feature| %>
                        <li class="flex items-start gap-2 text-sm text-bilus-600">
                            <svg class="w-4 h-4 text-bilus-400 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                            </svg>
                            <%= feature %>
                        </li>
                        <% end %>
                    </ul>

                    <div class="flex flex-wrap gap-3 mb-6">
                        <% product.stats.each do |stat| %>
                        <div class="bg-bilus-100/20 border border-bilus-100 rounded-lg px-4 py-2 text-center">
                            <div class="text-bilus-600 font-bold text-lg"><%= stat.value %></div>
                            <div class="text-bilus-400 text-xs"><%= stat.label %></div>
                        </div>
                        <% end %>
                    </div>

                    <div class="flex flex-wrap gap-2 mb-6">
                        <% product.tech.each do |t| %>
                        <span class="text-xs bg-bilus-800 text-white rounded-full px-3 py-1"><%= t %></span>
                        <% end %>
                    </div>

                    <div class="flex items-center gap-4 flex-wrap">
                        <% if product.respond_to?(:url) && product.url.present? %>
                        <a href="<%= product.url %>" target="_blank" rel="noopener noreferrer" title="<%= product.name %>" class="inline-flex items-center gap-2 bg-bilus-700 text-white px-6 py-2 font-bold rounded-full hover:bg-bilus-500 transition duration-200 ease-in-out text-sm">
                            Uygulamaya Git
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
                                <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd"/>
                            </svg>
                        </a>
                        <% end %>
                        <% if product.respond_to?(:ios_app) && product.ios_app %>
                        <span class="inline-flex items-center gap-1.5 text-xs text-gray-500 bg-gray-100 border border-gray-200 rounded-full px-3 py-1.5 font-medium">
                            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                            iOS App
                        </span>
                        <% end %>
                        <% if product.respond_to?(:stripe) && product.stripe %>
                        <a href="https://stripe.com" target="_blank" rel="noopener noreferrer" title="Powered by Stripe">
                            <%= image_tag "powered-by-stripe.svg", alt: "Powered by Stripe", class: "h-8 opacity-70 hover:opacity-100 transition" %>
                        </a>
                        <% end %>
                    </div>
                </div>

            </div>
            <% end %>
        </div>

    </div>
</section>
